{
  "name": "fullstack-nuxt-starter",
  "version": "0.1.0",
  "description": "Nuxt fullstack starter with magic-link auth, Kysely, pg-boss, and a dashboard shell.",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "NITRO_PRESET=node-server nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix --quiet",
    "db:migrate": "tsx server/db/migrate.ts latest",
    "db:status": "tsx server/db/migrate.ts status",
    "db:up": "tsx server/db/migrate.ts up",
    "db:down": "tsx server/db/migrate.ts down",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@internationalized/date": "^3.12.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/device": "4.0.0",
    "@pinia/nuxt": "0.11.3",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/vue-table": "^8.21.3",
    "@unovis/ts": "^1.6.4",
    "@unovis/vue": "^1.6.4",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "kysely": "^0.28.11",
    "lucide-vue-next": "^0.575.0",
    "nodemailer": "^8.0.1",
    "nuxt": "^4.4.2",
    "nuxt-auth-utils": "0.5.29",
    "pg": "^8.18.0",
    "pg-boss": "^12.13.0",
    "pinia": "^3.0.4",
    "pino": "^10.3.1",
    "reka-ui": "^2.9.2",
    "shadcn-nuxt": "2.4.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxtjs/html-validator": "^2.1.0",
    "@types/node": "^24.12.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.16.0",
    "eslint": "^10.1.0",
    "eslint-plugin-harlanzw": "^0.12.0",
    "eslint-plugin-tailwindcss": "^4.0.0-beta.0",
    "lefthook": "^2.1.4",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.6"
  }
}
