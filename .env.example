PORT=3000
NODE_ENV=development

NUXT_PUBLIC_APP_NAME="Fullstack Starter"
NUXT_PUBLIC_BASE_URL="http://localhost:3000"
NUXT_SESSION_PASSWORD="change-me-to-a-long-random-string-with-at-least-32-characters"
NUXT_SESSION_COOKIE_SECURE=false

AUTH_MAGIC_LINK_TTL_MINUTES=20

DB_HOST=localhost
DB_PORT=5432
DB_USER=starter
DB_PASSWORD=starter
DB_NAME=starter
DB_SSL=false
DATABASE_URL=postgresql://starter:starter@localhost:5432/starter

MAIL_MODE=console
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_POOL=false
SMTP_MAX_CONNECTIONS=5
SMTP_MAX_MESSAGES=100
SMTP_TLS_REJECT_UNAUTHORIZED=false
SMTP_USER=
SMTP_PASS=
MAILER_DEFAULT_FROM="Starter <noreply@example.com>"
MAILER_DEFAULT_REPLY_TO=""
MAILER_DEFAULT_PRIORITY=normal

PGBOSS_APP_NAME=fullstack_starter_queue
PGBOSS_SCHEMA=queue
PGBOSS_MIGRATE=true
PGBOSS_MAX_CONN=10
